# Copy to .env and fill in. The MVP works without this key (holidays only).
#
# Free Ticketmaster Discovery API key: https://developer.ticketmaster.com/
# Used to collect concerts / sports / arts events. If unset, only holidays
# (Nager.Date) are collected.
TICKETMASTER_API_KEY=

# Free API-Football (API-Sports) key: https://www.api-football.com/
# Used to collect league + cup football fixtures (Süper Lig, UEFA, top European
# leagues), including historical fixtures for backtesting. If unset, football is
# skipped cleanly (other sources still run).
FOOTBALL_API_KEY=

# Impact scoring via an LLM (optional; default scorer is the offline heuristic).
# --impact-scorer openai  -> OpenAI chat completions (default model gpt-5-mini)
OPENAI_API_KEY=

# --impact-scorer vllm    -> any OpenAI-compatible vLLM server
# VLLM_BASE_URL example: http://localhost:8000/v1
VLLM_BASE_URL=
# VLLM_API_KEY is often unused by vLLM; leave blank if not required
VLLM_API_KEY=
# VLLM_MODEL is the model name your vLLM server serves
VLLM_MODEL=

# --impact-scorer azure   -> Azure OpenAI
# AZURE_OPENAI_ENDPOINT example: https://your-resource.openai.azure.com/
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_DEPLOYMENT is the name you gave the model deployment in Azure
AZURE_OPENAI_DEPLOYMENT=
# AZURE_OPENAI_API_VERSION is optional (default 2024-10-21); newer/reasoning models
# (e.g. gpt-5.1) need a preview version such as 2024-12-01-preview
AZURE_OPENAI_API_VERSION=
# AZURE_OPENAI_MAX_COMPLETION_TOKENS is optional (default 16384) — a generous budget
# so reasoning models don't spend it all thinking and return empty content
AZURE_OPENAI_MAX_COMPLETION_TOKENS=
