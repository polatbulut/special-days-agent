# Copy to .env and fill in. The MVP works without this key (holidays only).
#
# Free Ticketmaster Discovery API key: https://developer.ticketmaster.com/
# Used to collect concerts / sports / arts events. If unset, only holidays
# (Nager.Date) are collected.
TICKETMASTER_API_KEY=

# Impact scoring via an LLM (optional; default scorer is the offline heuristic).
# --impact-scorer openai  -> OpenAI chat completions (default model gpt-5-mini)
OPENAI_API_KEY=
# --impact-scorer vllm    -> any OpenAI-compatible vLLM server
VLLM_BASE_URL=          # e.g. http://localhost:8000/v1
VLLM_API_KEY=           # often unused by vLLM; leave blank if not required
VLLM_MODEL=             # the model name your vLLM server serves
